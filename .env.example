# Copy to .env.local for local development. On Vercel, set these as
# Environment Variables in the project settings instead.

# Required. Vercel Postgres (Neon) connection string.
# Vercel sets this automatically if you provision a Postgres database
# through the Vercel dashboard and link it to this project.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Optional. Until these are set, every source below runs in stub/mock mode.
# OTX_API_KEY=
# ABUSEIPDB_API_KEY=
# THREATFOX_AUTH_KEY=
# URLHAUS_AUTH_KEY=
# MALWAREBAZAAR_AUTH_KEY=
